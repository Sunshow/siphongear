# Required: 32+ bytes for AES-GCM credential encryption
SIPHON_AUTH__MASTER_KEY=change-me-please-32bytes-or-more!!

# Required: 32+ bytes for JWT signing
SIPHON_AUTH__JWT_SECRET=change-me-please-32bytes-or-more!!

# Optional: initial admin (only used when no users exist yet)
SIPHON_AUTH__INIT_USERNAME=admin
SIPHON_AUTH__INIT_PASSWORD=admin

# Optional: external Chrome DevTools websocket for browser fetch step
# SIPHON_BROWSER__WS_URL=ws://chrome:9222/devtools/browser
